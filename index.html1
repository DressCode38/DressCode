<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="theme-color" content="#0d0118"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="DressCode"/>
<title>DressCode</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;font-family:'DM Sans',sans-serif;background:#0d0118;position:fixed;width:100%}
:root{
  --purple:#7c3aed;--purple-light:#a78bfa;--purple-dark:#4c1d95;--purple-glow:#7c3aed44;
  --gold:#f4c542;--bg:#0d0118;--bg2:#160828;--bg3:#1f0a38;--card:#1e0d35;--card2:#28114a;
  --text:#f0e9ff;--text2:#b39fd4;--text3:#7a6494;
  --border:rgba(124,58,237,0.25);--border2:rgba(124,58,237,0.12);
  --radius:16px;--radius-sm:10px;--radius-lg:24px;
}
#app{width:100%;height:100%;position:relative;overflow:hidden}
.screen{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transform:translateY(20px);transition:opacity .45s ease,transform .45s ease;overflow:hidden;z-index:1}
.screen.active{opacity:1;pointer-events:all;transform:translateY(0);z-index:10}

/* SPLASH */
#splash{background:var(--bg);justify-content:center;align-items:center}
.splash-orb{position:absolute;border-radius:50%;filter:blur(80px);animation:pulse 4s ease-in-out infinite}
.orb1{width:350px;height:350px;background:rgba(124,58,237,0.35);top:-80px;left:-80px}
.orb2{width:280px;height:280px;background:rgba(167,139,250,0.2);bottom:-60px;right:-60px;animation-delay:1.5s}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
.splash-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:0}
.splash-logo{width:100px;height:100px;background:linear-gradient(135deg,#4c1d95,#7c3aed);border-radius:28px;display:flex;align-items:center;justify-content:center;margin-bottom:28px;box-shadow:0 0 60px var(--purple-glow),0 20px 40px rgba(0,0,0,0.5);animation:logoIn 1s cubic-bezier(.34,1.56,.64,1) both}
@keyframes logoIn{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.splash-name{font-family:'Playfair Display',serif;font-size:42px;font-weight:700;color:var(--text);animation:fadeUp .8s .3s both}
.splash-name span{color:var(--purple-light)}
.splash-tagline{font-size:13px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;margin-top:6px;animation:fadeUp .8s .5s both}
.splash-loader{margin-top:60px;width:120px;height:2px;background:var(--card2);border-radius:2px;overflow:hidden;animation:fadeUp .8s .7s both}
.splash-loader-bar{height:100%;background:linear-gradient(90deg,var(--purple),var(--purple-light));border-radius:2px;width:0%;transition:width .08s linear}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* AUTH */
#auth{background:var(--bg)}
.auth-orb{position:absolute;border-radius:50%;filter:blur(100px)}
.auth-orb1{width:400px;height:400px;background:rgba(124,58,237,0.2);top:-150px;right:-100px}
.auth-orb2{width:300px;height:300px;background:rgba(167,139,250,0.12);bottom:-100px;left:-80px}
.auth-inner{position:relative;z-index:2;flex:1;display:flex;flex-direction:column;overflow-y:auto;padding:0 0 24px}
.auth-top{padding:50px 28px 30px;display:flex;flex-direction:column;align-items:flex-start}
.auth-logo-small{width:44px;height:44px;background:var(--purple);border-radius:13px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;box-shadow:0 4px 20px var(--purple-glow)}
.auth-title{font-family:'Playfair Display',serif;font-size:30px;color:var(--text);font-weight:700;line-height:1.2}
.auth-subtitle{font-size:14px;color:var(--text3);margin-top:6px}
.auth-form{padding:0 24px;display:flex;flex-direction:column;gap:12px;flex:1;position:relative;z-index:20}
.input-group{display:flex;flex-direction:column;gap:6px}
.input-label{font-size:11px;color:var(--text2);font-weight:500;letter-spacing:.5px;text-transform:uppercase;padding-left:4px}
.dc-input{width:100%;padding:15px 18px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s,box-shadow .2s}
.dc-input::placeholder{color:var(--text3)}
.dc-input:focus{border-color:var(--purple);box-shadow:0 0 0 3px var(--purple-glow)}
.pw-wrap{position:relative}
.pw-wrap .dc-input{padding-right:50px}
.eye-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);font-size:18px;padding:4px;line-height:1}
.remember-row{display:flex;align-items:center;justify-content:space-between;padding:0 2px}
.remember-label{display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none}
.checkbox{width:20px;height:20px;border-radius:6px;border:1.5px solid var(--border);background:var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0}
.checkbox.checked{background:var(--purple);border-color:var(--purple)}
.remember-text{font-size:13px;color:var(--text2)}
.forgot-btn{background:none;border:none;color:var(--purple-light);font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif}
.dc-btn{width:100%;padding:16px;background:var(--purple);color:#fff;border:none;border-radius:var(--radius-sm);font-size:16px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:transform .15s,box-shadow .2s;box-shadow:0 4px 20px var(--purple-glow)}
.dc-btn:active{transform:scale(0.98)}
.dc-btn.loading{opacity:.7;pointer-events:none}
.dc-btn-outline{width:100%;padding:14px;background:transparent;color:var(--purple-light);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.dc-btn-outline:hover{background:var(--card)}
.auth-divider{display:flex;align-items:center;gap:12px;margin:2px 0}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border2)}
.auth-divider span{font-size:12px;color:var(--text3)}
.auth-error{background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.3);border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;color:#f87171;display:none}
.auth-error.visible{display:block}
.auth-switch-text{text-align:center;font-size:12px;color:var(--text3)}
.auth-switch-text button{background:none;border:none;color:var(--purple-light);font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:underline}

/* MAIN APP */
#main{background:var(--bg)}
.app-header{background:linear-gradient(180deg,var(--bg2),var(--bg));border-bottom:1px solid var(--border2);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;padding-top:calc(env(safe-area-inset-top,0px) + 14px)}
.app-header-left{display:flex;align-items:center;gap:10px}
.header-logo{width:34px;height:34px;background:var(--purple);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px var(--purple-glow)}
.user-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--purple-light));display:flex;align-items:center;justify-content:center;font-size:13px;color:#fff;font-weight:500;border:1.5px solid var(--border)}
.tab-area{flex:1;overflow:hidden;position:relative}
.tab-panel{position:absolute;inset:0;overflow-y:auto;padding:20px 16px;opacity:0;pointer-events:none;transform:translateY(10px);transition:opacity .3s,transform .3s;-webkit-overflow-scrolling:touch}
.tab-panel.active{opacity:1;pointer-events:all;transform:translateY(0)}
.bottom-nav{background:var(--bg2);border-top:1px solid var(--border2);display:grid;grid-template-columns:repeat(4,1fr);padding:8px 0 calc(env(safe-area-inset-bottom,0px) + 8px);flex-shrink:0}
.nav-item{display:flex;flex-direction:column;align-items:center;gap:4px;padding:6px 4px;cursor:pointer;transition:transform .15s}
.nav-item:active{transform:scale(0.9)}
.nav-icon-wrap{width:44px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:14px;transition:background .2s}
.nav-item.active .nav-icon-wrap{background:rgba(124,58,237,0.2)}
.nav-svg{width:22px;height:22px;stroke:var(--text3);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.nav-item.active .nav-svg{stroke:var(--purple-light)}
.nav-label{font-size:9px;color:var(--text3);transition:color .2s}
.nav-item.active .nav-label{color:var(--purple-light);font-weight:500}
.section-title{font-family:'Playfair Display',serif;font-size:22px;color:var(--text);font-weight:700;margin-bottom:4px}
.section-sub{font-size:13px;color:var(--text3);margin-bottom:20px}

/* DRESSING */
.ai-card{background:linear-gradient(135deg,var(--purple-dark),var(--purple));border-radius:var(--radius);padding:20px;margin-bottom:20px;position:relative;overflow:hidden;box-shadow:0 8px 32px var(--purple-glow)}
.ai-card::before{content:'';position:absolute;top:-40px;right:-40px;width:150px;height:150px;border-radius:50%;background:rgba(255,255,255,0.06)}
.ai-card h3{font-family:'Playfair Display',serif;font-size:18px;color:#fff;margin-bottom:4px;position:relative}
.ai-card p{font-size:13px;color:rgba(255,255,255,0.7);margin-bottom:16px;position:relative}
.ai-btn{display:inline-flex;align-items:center;gap:8px;padding:11px 20px;background:#fff;color:var(--purple-dark);border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:transform .15s;position:relative}
.ai-btn:active{transform:scale(0.97)}
.dressing-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.dressing-header h3{font-size:15px;color:var(--text);font-weight:500}
.add-photo-btn{display:flex;align-items:center;gap:6px;padding:8px 14px;background:var(--card);border:1px dashed var(--border);border-radius:var(--radius-sm);color:var(--purple-light);font-size:13px;cursor:pointer}
.clothes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.cloth-item{background:var(--card);border:1px solid var(--border2);border-radius:var(--radius-sm);aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;position:relative}
.cloth-emoji{font-size:32px;margin-bottom:4px}
.cloth-name{font-size:9px;color:var(--text3);text-align:center;padding:0 4px}
.cloth-badge{position:absolute;top:5px;right:5px;background:var(--purple);border-radius:50%;width:18px;height:18px;font-size:9px;color:#fff;display:flex;align-items:center;justify-content:center}
.add-cloth-item{border:1.5px dashed var(--border);border-radius:var(--radius-sm);aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;cursor:pointer;color:var(--text3);font-size:11px}
.add-cloth-plus{font-size:22px;color:var(--purple-light)}
.ai-result{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-top:16px;display:none;animation:fadeUp .4s both}
.ai-result.visible{display:block}
.ai-result-header{display:flex;align-items:center;gap:8px;margin-bottom:12px}
.spark-badge{width:28px;height:28px;background:var(--purple);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 10px var(--purple-glow)}
.ai-mood{font-size:11px;color:var(--purple-light);background:rgba(124,58,237,0.12);border-radius:20px;padding:4px 10px;display:inline-block;margin-bottom:12px}
.outfit-tags{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:12px}
.outfit-tag{background:var(--card2);border:1px solid var(--border);border-radius:20px;padding:6px 13px;font-size:12px;color:var(--text)}
.ai-advice{font-size:12px;color:var(--text3);line-height:1.6;border-top:1px solid var(--border2);padding-top:12px}
.ai-loading{display:none;align-items:center;gap:10px;padding:16px;color:var(--text3);font-size:13px}
.ai-loading.visible{display:flex}
.ai-spinner{width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--purple);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* AVATAR */
.avatar-stage{background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:20px 16px;display:flex;flex-direction:column;align-items:center;margin-bottom:20px;position:relative;overflow:hidden}
.avatar-stage::before{content:'';position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(0deg,rgba(124,58,237,0.08),transparent)}
.avatar-caption{font-size:12px;color:var(--text3);margin-top:10px;position:relative;z-index:1}
.avatar-photo-btns{display:flex;gap:10px;margin-top:14px;width:100%;position:relative;z-index:1}
.avatar-photo-btns label{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:11px;border-radius:var(--radius-sm);font-size:13px;cursor:pointer;font-weight:500}
.avatar-photo-btns label.primary{background:var(--purple);color:#fff}
.avatar-photo-btns label.secondary{background:var(--card2);border:1px solid var(--border);color:var(--text)}
.customizer{display:flex;flex-direction:column;gap:14px}
.custom-section{background:var(--card);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:14px}
.custom-section-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px}
.color-palette{display:flex;gap:8px;flex-wrap:wrap}
.color-swatch{width:28px;height:28px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .15s,border-color .15s}
.color-swatch.selected{border-color:#fff;transform:scale(1.1)}
.avatar-option-row{display:flex;gap:8px}
.avatar-option{flex:1;background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:10px 8px;text-align:center;cursor:pointer;transition:border-color .2s,background .2s}
.avatar-option.selected{border-color:var(--purple);background:rgba(124,58,237,0.12)}
.avatar-option-icon{font-size:22px;display:block;margin-bottom:4px}
.avatar-option-label{font-size:10px;color:var(--text3)}
.avatar-option.selected .avatar-option-label{color:var(--purple-light)}

/* ABONNEMENTS */
.sub-cards{display:flex;flex-direction:column;gap:12px}
.sub-card{background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:20px;position:relative;overflow:hidden}
.sub-card.featured{border-color:var(--purple);background:linear-gradient(135deg,var(--card),rgba(124,58,237,0.12))}
.sub-card.featured::after{content:'POPULAIRE';position:absolute;top:16px;right:-22px;background:var(--gold);color:#1a0533;font-size:9px;font-weight:700;letter-spacing:1px;padding:4px 30px;transform:rotate(45deg)}
.sub-plan-name{font-size:12px;font-weight:500;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.sub-card.featured .sub-plan-name{color:var(--purple-light)}
.sub-price-row{display:flex;align-items:baseline;gap:4px;margin-bottom:14px}
.sub-amount{font-family:'Playfair Display',serif;font-size:34px;color:var(--text);font-weight:700}
.sub-period{font-size:13px;color:var(--text3)}
.sub-features{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
.sub-feature{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text2)}
.sub-check{width:18px;height:18px;border-radius:50%;background:rgba(124,58,237,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--purple-light);font-size:10px;font-weight:700}
.sub-cta{width:100%;padding:13px;background:var(--card2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer}
.sub-card.featured .sub-cta{background:var(--purple);border-color:transparent;color:#fff;box-shadow:0 4px 16px var(--purple-glow)}

/* PARAMÈTRES */
.settings-group{margin-bottom:20px}
.settings-group-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px;padding-left:4px}
.setting-row{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;background:var(--card);border:1px solid var(--border2);border-radius:var(--radius-sm);margin-bottom:4px;cursor:pointer}
.setting-left{display:flex;align-items:center;gap:12px}
.setting-icon{width:32px;height:32px;border-radius:9px;background:rgba(124,58,237,0.15);display:flex;align-items:center;justify-content:center;font-size:15px}
.setting-label{font-size:14px;color:var(--text)}
.setting-meta{font-size:12px;color:var(--text3);margin-top:1px}
.setting-value{font-size:13px;color:var(--text3)}
.setting-arrow{font-size:14px;color:var(--text3)}
.toggle-switch{width:42px;height:24px;background:var(--card2);border-radius:12px;position:relative;border:1px solid var(--border);transition:background .2s;cursor:pointer}
.toggle-switch.on{background:var(--purple);border-color:transparent}
.toggle-switch::after{content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:2px;left:2px;transition:left .2s;box-shadow:0 1px 4px rgba(0,0,0,0.3)}
.toggle-switch.on::after{left:20px}
.api-key-row{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px 16px;margin-bottom:4px}
.api-key-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.api-key-input-wrap{display:flex;gap:8px}
.api-key-input{flex:1;background:var(--card2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;outline:none}
.api-key-input:focus{border-color:var(--purple)}
.api-save-btn{padding:10px 14px;background:var(--purple);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap}
.logout-btn{width:100%;padding:14px;background:transparent;border:1px solid rgba(239,68,68,0.3);border-radius:var(--radius-sm);color:#f87171;font-size:14px;font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:8px}

/* TOAST */
.toast{position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 90px);left:50%;transform:translateX(-50%) translateY(20px);background:var(--card2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 20px;font-size:13px;color:var(--text);white-space:nowrap;opacity:0;transition:opacity .3s,transform .3s;z-index:999;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,0.4)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div id="app">

<!-- SPLASH -->
<div class="screen active" id="splash">
  <div class="splash-orb orb1"></div>
  <div class="splash-orb orb2"></div>
  <div class="splash-content">
    <div class="splash-logo">
      <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
        <path d="M26 12 C26 12 26 7 26 6 A4 4 0 0 1 34 6" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <path d="M26 12 L8 36 Q6 38 8 40 Q10 42 12 40 L26 28 L40 40 Q42 42 44 40 Q46 38 44 36 Z" fill="white"/>
      </svg>
    </div>
    <div class="splash-name">Dress<span>Code</span></div>
    <div class="splash-tagline">Votre style, sublimé par l'IA</div>
    <div class="splash-loader"><div class="splash-loader-bar" id="loaderBar"></div></div>
  </div>
</div>

<!-- AUTH -->
<div class="screen" id="auth">
  <div class="auth-orb auth-orb1"></div>
  <div class="auth-orb auth-orb2"></div>
  <div class="auth-inner">
    <div class="auth-top">
      <div class="auth-logo-small">
        <svg width="24" height="24" viewBox="0 0 52 52" fill="none">
          <path d="M26 12 C26 12 26 7 26 6 A4 4 0 0 1 34 6" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <path d="M26 12 L8 36 Q6 38 8 40 Q10 42 12 40 L26 28 L40 40 Q42 42 44 40 Q46 38 44 36 Z" fill="white"/>
        </svg>
      </div>
      <div class="auth-title" id="authTitle">Créer<br/>mon compte</div>
      <div class="auth-subtitle" id="authSubtitle">Rejoignez DressCode gratuitement</div>
    </div>
    <div class="auth-form">
      <div class="auth-error" id="authError"></div>
      <div class="input-group" id="nameGroup">
        <label class="input-label">Prénom</label>
        <input class="dc-input" id="nameInput" type="text" placeholder="Votre prénom" autocomplete="given-name"/>
      </div>
      <div class="input-group">
        <label class="input-label">Email</label>
        <input class="dc-input" id="emailInput" type="email" placeholder="votre@email.com" autocomplete="email"/>
      </div>
      <div class="input-group">
        <label class="input-label">Mot de passe</label>
        <div class="pw-wrap">
          <input class="dc-input" id="passwordInput" type="password" placeholder="••••••••" autocomplete="current-password"/>
          <button class="eye-btn" id="eyeBtn" type="button" onclick="togglePw()">👁️</button>
        </div>
      </div>
      <div class="remember-row">
        <div class="remember-label" onclick="toggleRemember()">
          <div class="checkbox" id="rememberBox"></div>
          <span class="remember-text">Se souvenir de moi</span>
        </div>
        <button class="forgot-btn" type="button" onclick="showToast('Bientôt disponible')">Mot de passe oublié ?</button>
      </div>
      <button class="dc-btn" id="authBtn" onclick="handleAuth()">Créer mon compte</button>
      <div class="auth-divider"><span>ou</span></div>
      <button class="dc-btn-outline" id="faceIdBtn" onclick="handleFaceId()">
        <span>🔐</span><span id="biometricLabel">Connexion Face ID / Empreinte</span>
      </button>
      <button class="dc-btn-outline" onclick="toggleAuthMode()">
        <span id="authToggleLabel">J'ai déjà un compte – Me connecter</span>
      </button>
      <div class="auth-switch-text">En continuant vous acceptez les <button onclick="showToast('Conditions bientôt disponibles')">conditions d'utilisation</button></div>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div class="screen" id="main">
  <div class="app-header">
    <div class="app-header-left">
      <div class="header-logo">
        <svg width="20" height="20" viewBox="0 0 52 52" fill="none">
