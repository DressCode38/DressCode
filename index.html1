      <div class="clothes-grid" id="clothesGrid">
        <div class="cloth-item"><div class="cloth-emoji">👔</div><div class="cloth-name">Chemise blanche</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👖</div><div class="cloth-name">Jean slim bleu</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👟</div><div class="cloth-name">Sneakers blanches</div></div>
        <div class="cloth-item"><div class="cloth-emoji">🧥</div><div class="cloth-name">Blazer marine</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👗</div><div class="cloth-name">Robe fleurie</div></div>
        <label class="add-cloth-item" for="clothInput"><div class="add-cloth-plus">+</div>Photographier</label>
