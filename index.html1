<div class="toast" id="toast"></div>

<script>
// ── FIREBASE CONFIG ──
const firebaseConfig = {
  apiKey: "AIzaSyCMGAZ4OeKhDskKIVM-tnpyH14E1ebD1_g",
  authDomain: "dresscode-69adb.firebaseapp.com",
  projectId: "dresscode-69adb",
  storageBucket: "dresscode-69adb.firebasestorage.app",
  messagingSenderId: "824734866282",
  appId: "1:824734866282:web:88650ff621bef6e3242313"
};

let auth, db, currentUser;
let ANTHROPIC_API_KEY = localStorage.getItem('dc_api_key') || '';
let isLoginMode = false;
let rememberMe = false;
let pwVisible = false;
let outfitCount = 0;

// ── INIT FIREBASE ──
try {
  firebase.initializeApp(firebaseConfig);
  auth = firebase.auth();
  db = firebase.firestore();
  auth.onAuthStateChanged(function(user) {
    if (user) {
      currentUser = user;
      var splash = document.getElementById('splash');
      if (splash && splash.classList.contains('active')) {
        setTimeout(function() { onUserLoggedIn(user); }, 1500);
      } else {
        onUserLoggedIn(user);
      }
    }
  });
} catch(e) {
  console.warn('Firebase non disponible:', e.message);
}

// ── SPLASH ──
var progress = 0;
var bar = document.getElementById('loaderBar');
var loaderInterval = setInterval(function() {
  progress = Math.min(progress + Math.random() * 3 + 1, 100);
  bar.style.width = progress + '%';
  if (progress >= 100) {
    clearInterval(loaderInterval);
    setTimeout(function() {
      if (!currentUser) showScreen('auth');
    }, 400);
  }
}, 60);

// ── SCREENS ──
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
  document.getElementById(id).classList.add('active');
}

// ── AUTH MODE ──
function toggleAuthMode() {
  isLoginMode = !isLoginMode;
  document.getElementById('nameGroup').style.display = isLoginMode ? 'none' : '';
  document.getElementById('authTitle').innerHTML = isLoginMode ? 'Bon<br/>retour !' : 'Créer<br/>mon compte';
  document.getElementById('authSubtitle').textContent = isLoginMode ? 'Connectez-vous à DressCode' : 'Rejoignez DressCode gratuitement';
  document.getElementById('authBtn').textContent = isLoginMode ? 'Me connecter' : 'Créer mon compte';
  document.getElementById('authToggleLabel').textContent = isLoginMode ? "Pas encore de compte – S'inscrire" : "J'ai déjà un compte – Me connecter";
  clearAuthError();
}

function showAuthError(msg) {
  var el = document.getElementById('authError');
  el.textContent = msg;
  el.classList.add('visible');
}
function clearAuthError() {
  document.getElementById('authError').classList.remove('visible');
}

// ── PASSWORD TOGGLE ──
function togglePw() {
  pwVisible = !pwVisible;
  document.getElementById('passwordInput').type = pwVisible ? 'text' : 'password';
  document.getElementById('eyeBtn').textContent = pwVisible ? '🙈' : '👁️';
}

// ── REMEMBER ME ──
function toggleRemember() {
  rememberMe = !rememberMe;
  var box = document.getElementById('rememberBox');
  if (rememberMe) {
    box.classList.add('checked');
    box.innerHTML = '<span style="color:#fff;font-size:12px;font-weight:700">✓</span>';
  } else {
    box.classList.remove('checked');
    box.innerHTML = '';
  }
}

// ── FACE ID ──
async function handleFaceId() {
  if (!window.PublicKeyCredential) {
    showToast('Face ID non disponible sur cet appareil');
    return;
  }
  var savedEmail = localStorage.getItem('dc_saved_email');
  var savedPw = localStorage.getItem('dc_saved_pw');
  if (!savedEmail || !savedPw) {
    showToast('Connectez-vous d\'abord avec Se souvenir de moi');
    return;
  }
  try {
    var available = await PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable();
    if (!available) { showToast('Aucun capteur biometrique detecte'); return; }
    showToast('Authentification biometrique...');
    var result = await auth.signInWithEmailAndPassword(savedEmail, atob(savedPw));
    onUserLoggedIn(result.user);
    showToast('Connexion Face ID reussie !');
  } catch(e) {
    showToast('Face ID non disponible');
  }
}

// Cacher Face ID si non disponible
if (window.PublicKeyCredential) {
  PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable().then(function(ok) {
    if (!ok) document.getElementById('faceIdBtn').style.display = 'none';
  });
} else {
  document.getElementById('faceIdBtn').style.display = 'none';
}

// ── HANDLE AUTH ──
async function handleAuth() {
  var email = document.getElementById('emailInput').value.trim();
  var password = document.getElementById('passwordInput').value;
  var name = document.getElementById('nameInput').value.trim();
  var btn = document.getElementById('authBtn');
  clearAuthError();
  if (!email || !password) { showAuthError('Merci de remplir tous les champs.'); return; }
  if (!isLoginMode && !name) { showAuthError('Entrez votre prénom.'); return; }
  if (password.length < 6) { showAuthError('Le mot de passe doit faire au moins 6 caractères.'); return; }
  btn.classList.add('loading');
  btn.disabled = true;
  try {
    var persistence = rememberMe ? firebase.auth.Auth.Persistence.LOCAL : firebase.auth.Auth.Persistence.SESSION;
    await auth.setPersistence(persistence);
    if (isLoginMode) {
      var result = await auth.signInWithEmailAndPassword(email, password);
      if (rememberMe) { localStorage.setItem('dc_saved_email', email); localStorage.setItem('dc_saved_pw', btoa(password)); }
      onUserLoggedIn(result.user);
    } else {
      var cred = await auth.createUserWithEmailAndPassword(email, password);
      await cred.user.updateProfile({ displayName: name });
      if (rememberMe) { localStorage.setItem('dc_saved_email', email); localStorage.setItem('dc_saved_pw', btoa(password)); }
      try { if (db) await db.collection('users').doc(cred.user.uid).set({ name: name, email: email, createdAt: new Date().toISOString() }); } catch(e) {}
      onUserLoggedIn(cred.user);
    }
  } catch(e) {
    var msgs = {
      'auth/email-already-in-use': 'Cet email est déjà utilisé.',
      'auth/user-not-found': 'Aucun compte avec cet email.',
      'auth/wrong-password': 'Mot de passe incorrect.',
      'auth/invalid-credential': 'Email ou mot de passe incorrect.',
      'auth/invalid-email': 'Email invalide.',
      'auth/too-many-requests': 'Trop de tentatives. Réessayez plus tard.',
      'auth/network-request-failed': 'Erreur réseau. Vérifiez votre connexion.',
    };
    showAuthError(msgs[e.code] || 'Erreur : ' + e.message);
    btn.classList.remove('loading');
    btn.disabled = false;
  }
}

function onUserLoggedIn(user) {
  currentUser = user;
  var name = user.displayName || user.email || 'U';
  document.getElementById('userBadge').textContent = name.charAt(0).toUpperCase();
  document.getElementById('userEmailDisplay').textContent = user.email || name;
  if (ANTHROPIC_API_KEY) document.getElementById('apiKeyInput').value = '••••••••';
  showScreen('main');
}

function handleLogout() {
  if (auth) auth.signOut();
  localStorage.removeItem('dc_saved_email');
  localStorage.removeItem('dc_saved_pw');
  showScreen('auth');
  showToast('A bientot !');
}

// ── TABS ──
var tabTitles = { dressing: 'Mon dressing', avatar: 'Mon avatar', sub: 'Abonnements', settings: 'Parametres' };
function switchTab(tab) {
  ['dressing','avatar','sub','settings'].forEach(function(t) {
    var panel = document.getElementById('panel' + t.charAt(0).toUpperCase() + t.slice(1));
    var nav = document.getElementById('nav' + t.charAt(0).toUpperCase() + t.slice(1));
    if (panel) panel.classList.toggle('active', t === tab);
    if (nav) nav.classList.toggle('active', t === tab);
  });
  document.getElementById('currentTabTitle').textContent = tabTitles[tab] || '';
}

// ── AVATAR ──
function applyAvatarPhoto(e) {
  var file = e.target.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var img = document.getElementById('avatarPhotoImg');
    img.src = ev.target.result;
    document.getElementById('avatarPhotoPreview').style.display = 'block';
    var defs = document.getElementById('avatarDefs');
    defs.innerHTML = '<pattern id="facePattern" patternUnits="objectBoundingBox" width="1" height="1"><image href="' + ev.target.result + '" width="60" height="68" preserveAspectRatio="xMidYMid slice"/></pattern>';
    document.getElementById('avHead').setAttribute('fill', 'url(#facePattern)');
    document.getElementById('avHair').setAttribute('fill', 'none');
    showToast('Avatar mis a jour !');
  };
  reader.readAsDataURL(file);
}

function setAvatarColor(el) {
  var type = el.dataset.type;
  var val = el.dataset.val;
  el.closest('.color-palette').querySelectorAll('.color-swatch').forEach(function(s) { s.classList.remove('selected'); });
  el.classList.add('selected');
  if (type === 'skin') {
    document.getElementById('avHead').setAttribute('fill', val);
    document.getElementById('avNeck').setAttribute('fill', val);
  } else if (type === 'hair') {
    document.getElementById('avHair').setAttribute('fill', val);
  } else if (type === 'shirt') {
    document.getElementById('avShirt').setAttribute('fill', val);
    document.getElementById('avArmL').setAttribute('fill', val);
    document.getElementById('avArmR').setAttribute('fill', val);
  }
}

function selectHairStyle(el, style) {
  el.closest('.avatar-option-row').querySelectorAll('.avatar-option').forEach(function(o) { o.classList.remove('selected'); });
  el.classList.add('selected');
  var hair = document.getElementById('avHair');
  if (style === 'short') hair.setAttribute('d', 'M40 42 Q40 18 70 16 Q100 18 100 42 Q100 30 70 28 Q40 30 40 42Z');
  if (style === 'medium') hair.setAttribute('d', 'M40 42 Q38 18 70 14 Q102 18 100 42 Q100 28 70 26 Q40 28 40 42 M40 42 Q35 60 38 70 M100 42 Q105 60 102 70Z');
  if (style === 'long') hair.setAttribute('d', 'M40 42 Q36 18 70 12 Q104 18 100 42 Q100 26 70 24 Q40 26 40 42 M40 42 Q32 65 34 90 M100 42 Q108 65 106 90Z');
  showToast('Style applique !');
}

// ── DRESSING ──
function addCloth(e) {
  var file = e.target.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var grid = document.getElementById('clothesGrid');
    var last = grid.querySelector('.add-cloth-item');
    var div = document.createElement('div');
    div.className = 'cloth-item';
    div.innerHTML = '<img src="' + ev.target.result + '" style="width:100%;height:100%;object-fit:cover"/><div class="cloth-badge">✓</div>';
    grid.insertBefore(div, last);
    showToast('Vetement ajoute !');
  };
  reader.readAsDataURL(file);
}

// ── GENERATE OUTFIT ──
async function generateOutfit() {
  var loading = document.getElementById('aiLoading');
  var result = document.getElementById('aiResult');
  result.classList.remove('visible');
  loading.classList.add('visible');
  var clothes = ['Chemise blanche', 'Jean slim bleu', 'Sneakers blanches', 'Blazer marine', 'Robe fleurie'];
  if (!ANTHROPIC_API_KEY) {
    await new Promise(function(r) { setTimeout(r, 1500); });
    loading.classList.remove('visible');
    showOutfit('Smart casual', ['Chemise blanche', 'Jean slim bleu', 'Sneakers blanches'], 'Retroussez les manches pour un effet plus decontracte.');
    return;
  }
  try {
    var resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_API_KEY, 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 400, messages: [{ role: 'user', content: 'Tu es un styliste expert. Vêtements disponibles: ' + clothes.join(', ') + '. Génère une tenue. Réponds UNIQUEMENT en JSON: {"mood":"style en 2-3 mots","items":["item1","item2","item3"],"conseil":"conseil court"}' }] })
    });
    var data = await resp.json();
    var text = data.content[0].text;
    var json = JSON.parse(text.replace(/```json|```/g, '').trim());
    loading.classList.remove('visible');
    showOutfit(json.mood, json.items, json.conseil);
  } catch(e) {
    loading.classList.remove('visible');
    showOutfit('Smart casual', ['Chemise blanche', 'Jean slim bleu', 'Sneakers blanches'], 'Un classique indémodable pour toutes les occasions.');
  }
}

function showOutfit(mood, items, conseil) {
  document.getElementById('aiMood').textContent = mood;
  document.getElementById('outfitTags').innerHTML = items.map(function(i) { return '<span class="outfit-tag">' + i + '</span>'; }).join('');
  document.getElementById('aiAdvice').textContent = 'Conseil : ' + conseil;
  document.getElementById('aiResult').classList.add('visible');
  outfitCount++;
  document.getElementById('outfitCount').textContent = outfitCount + ' tenue(s)';
}

// ── SETTINGS ──
function saveApiKey() {
  var val = document.getElementById('apiKeyInput').value.trim();
  if (!val || val === '••••••••') { showToast('Entrez votre cle API'); return; }
  ANTHROPIC_API_KEY = val;
  localStorage.setItem('dc_api_key', val);
  document.getElementById('apiKeyInput').value = '••••••••';
  showToast('Cle API enregistree !');
}

// ── TOAST ──
var toastTimer;
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function() { t.classList.remove('show'); }, 2800);
}
</script>
</body>
</html>
