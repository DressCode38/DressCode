<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="theme-color" content="#1a0533"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="DressCode"/>
<title>DressCode</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>

<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>

<style>
/* ── RESET & BASE ── */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;font-family:'DM Sans',sans-serif;background:#0d0118;position:fixed;width:100%}

/* ── CSS VARS ── */
:root{
  --purple:#7c3aed;
  --purple-light:#a78bfa;
  --purple-dark:#4c1d95;
  --purple-glow:#7c3aed44;
  --gold:#f4c542;
  --bg:#0d0118;
  --bg2:#160828;
  --bg3:#1f0a38;
  --card:#1e0d35;
  --card2:#28114a;
  --text:#f0e9ff;
  --text2:#b39fd4;
  --text3:#7a6494;
  --border:rgba(124,58,237,0.25);
  --border2:rgba(124,58,237,0.12);
  --radius:16px;
  --radius-sm:10px;
  --radius-lg:24px;
}

/* ── APP CONTAINER ── */
#app{
  width:100%;
  height:100%;
  position:relative;
  overflow:hidden;
}

/* ── SCREENS ── */
.screen{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  opacity:0;
  pointer-events:none;
  transform:translateY(20px);
  transition:opacity .45s cubic-bezier(.4,0,.2,1), transform .45s cubic-bezier(.4,0,.2,1);
  overflow:hidden;
  z-index:1;
}
.screen.active{
  opacity:1;
  pointer-events:all;
  transform:translateY(0);
  z-index:10;
}

/* ═══════════════════════════════
   SPLASH SCREEN
═══════════════════════════════ */
#splash{
  background:var(--bg);
  justify-content:center;
  align-items:center;
  gap:0;
}
.splash-bg{
  position:absolute;
  inset:0;
  overflow:hidden;
}
.splash-orb{
  position:absolute;
  border-radius:50%;
  filter:blur(80px);
  animation:pulse 4s ease-in-out infinite;
}
.orb1{width:350px;height:350px;background:rgba(124,58,237,0.35);top:-80px;left:-80px;animation-delay:0s}
.orb2{width:280px;height:280px;background:rgba(167,139,250,0.2);bottom:-60px;right:-60px;animation-delay:1.5s}
.orb3{width:200px;height:200px;background:rgba(244,197,66,0.1);bottom:30%;left:30%;animation-delay:0.8s}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}

.splash-content{
  position:relative;
  z-index:2;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:0;
}

.splash-logo{
  width:100px;
  height:100px;
  background:linear-gradient(135deg,#4c1d95,#7c3aed);
  border-radius:28px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:28px;
  box-shadow:0 0 60px var(--purple-glow), 0 20px 40px rgba(0,0,0,0.5);
  animation:logoIn 1s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes logoIn{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}

.hanger-svg{
  width:52px;
  height:52px;
}

.splash-name{
  font-family:'Playfair Display',serif;
  font-size:42px;
  font-weight:700;
  color:var(--text);
  letter-spacing:-0.5px;
  animation:fadeUp .8s .3s both;
}
.splash-name span{color:var(--purple-light)}
.splash-tagline{
  font-size:13px;
  color:var(--text3);
  letter-spacing:2px;
  text-transform:uppercase;
  margin-top:6px;
  animation:fadeUp .8s .5s both;
}

.splash-loader{
  margin-top:60px;
  width:120px;
  height:2px;
  background:var(--card2);
  border-radius:2px;
  overflow:hidden;
  animation:fadeUp .8s .7s both;
}
.splash-loader-bar{
  height:100%;
  background:linear-gradient(90deg,var(--purple),var(--purple-light));
  border-radius:2px;
  width:0%;
  transition:width .08s linear;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ═══════════════════════════════
   AUTH SCREEN
═══════════════════════════════ */
#auth{
  background:var(--bg);
}
.auth-bg{
  position:absolute;
  inset:0;
  overflow:hidden;
}
.auth-orb{
  position:absolute;
  border-radius:50%;
  filter:blur(100px);
}
.auth-orb1{width:400px;height:400px;background:rgba(124,58,237,0.2);top:-150px;right:-100px}
.auth-orb2{width:300px;height:300px;background:rgba(167,139,250,0.12);bottom:-100px;left:-80px}

.auth-inner{
  position:relative;
  z-index:2;
  flex:1;
  display:flex;
  flex-direction:column;
  overflow-y:auto;
  padding:0 0 24px;
}

.auth-top{
  padding:60px 32px 40px;
  display:flex;
  flex-direction:column;
  align-items:flex-start;
}
.auth-logo-small{
  width:44px;
  height:44px;
  background:var(--purple);
  border-radius:13px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:24px;
  box-shadow:0 4px 20px var(--purple-glow);
}
.auth-title{
  font-family:'Playfair Display',serif;
  font-size:32px;
  color:var(--text);
  font-weight:700;
  line-height:1.2;
}
.auth-subtitle{
  font-size:14px;
  color:var(--text3);
  margin-top:6px;
}

.auth-form{position:relative;z-index:20;
  padding:0 24px;
  display:flex;
  flex-direction:column;
  gap:12px;
  flex:1;
}

.input-group{
  display:flex;
  flex-direction:column;
  gap:6px;
}
.input-label{
  font-size:12px;
  color:var(--text2);
  font-weight:500;
  letter-spacing:.5px;
  text-transform:uppercase;
  padding-left:4px;
}
.dc-input{
  width:100%;
  padding:15px 18px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  color:var(--text);
  font-size:15px;
  font-family:'DM Sans',sans-serif;
  outline:none;
  transition:border-color .2s, box-shadow .2s;
}
.dc-input::placeholder{color:var(--text3)}
.dc-input:focus{
  border-color:var(--purple);
  box-shadow:0 0 0 3px var(--purple-glow);
}

.dc-btn{
  width:100%;
  padding:16px;
  background:var(--purple);
  color:#fff;
  border:none;
  border-radius:var(--radius-sm);
  font-size:16px;
  font-weight:500;
  font-family:'DM Sans',sans-serif;
  cursor:pointer;
  position:relative;
  overflow:hidden;
  transition:transform .15s, box-shadow .2s;
  box-shadow:0 4px 20px var(--purple-glow);
  margin-top:4px;
}
.dc-btn:active{transform:scale(0.98)}
.dc-btn:hover{box-shadow:0 6px 28px rgba(124,58,237,0.5)}
.dc-btn.loading::after{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.15) 50%,transparent 100%);
  animation:shimmer 1s infinite;
}
@keyframes shimmer{from{transform:translateX(-100%)}to{transform:translateX(100%)}}

.dc-btn-outline{
  width:100%;
  padding:14px;
  background:transparent;
  color:var(--purple-light);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  font-size:14px;
  font-family:'DM Sans',sans-serif;
  cursor:pointer;
  transition:background .2s, border-color .2s;
}
.dc-btn-outline:hover{background:var(--card);border-color:var(--purple)}

.auth-divider{
  display:flex;
  align-items:center;
  gap:12px;
  margin:4px 0;
}
.auth-divider::before,.auth-divider::after{
  content:'';flex:1;height:1px;background:var(--border2)
}
.auth-divider span{font-size:12px;color:var(--text3)}

.auth-error{
  background:rgba(220,38,38,0.1);
  border:1px solid rgba(220,38,38,0.3);
  border-radius:var(--radius-sm);
  padding:12px 16px;
  font-size:13px;
  color:#f87171;
  display:none;
}
.auth-error.visible{display:block}

.auth-switch-text{
  text-align:center;
  font-size:13px;
  color:var(--text3);
  padding-top:4px;
}
.auth-switch-text button{
  background:none;border:none;color:var(--purple-light);
  font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;
  text-decoration:underline;
}

/* ═══════════════════════════════
   MAIN APP
═══════════════════════════════ */
#main{
  background:var(--bg);
}

/* Header */
.app-header{
  background:linear-gradient(180deg,var(--bg2) 0%,var(--bg) 100%);
  border-bottom:1px solid var(--border2);
  padding:env(safe-area-inset-top, 12px) 20px 14px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  flex-shrink:0;
  padding-top:calc(env(safe-area-inset-top,0px) + 14px);
}
.app-header-left{display:flex;align-items:center;gap:10px}
.header-logo{
  width:34px;height:34px;
  background:var(--purple);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 2px 12px var(--purple-glow);
}
.app-header h1{
  font-family:'Playfair Display',serif;
  font-size:20px;
  color:var(--text);
  font-weight:700;
}
.header-tab-title{
  font-size:14px;
  color:var(--text2);
  margin-left:4px;
}
.header-actions{display:flex;gap:8px}
.header-btn{
  width:36px;height:36px;
  border-radius:50%;
  background:var(--card);
  border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  color:var(--text2);
  font-size:16px;
  transition:background .2s;
}
.header-btn:hover{background:var(--card2)}

/* Tab content area */
.tab-area{
  flex:1;
  overflow:hidden;
  position:relative;
}
.tab-panel{
  position:absolute;
  inset:0;
  overflow-y:auto;
  padding:20px 16px;
  opacity:0;
  pointer-events:none;
  transform:translateY(10px);
  transition:opacity .3s, transform .3s;
  -webkit-overflow-scrolling:touch;
}
.tab-panel.active{
  opacity:1;
  pointer-events:all;
  transform:translateY(0);
}

/* Bottom nav */
.bottom-nav{
  background:var(--bg2);
  border-top:1px solid var(--border2);
  display:grid;
  grid-template-columns:repeat(4,1fr);
  padding:8px 0 calc(env(safe-area-inset-bottom,0px) + 8px);
  flex-shrink:0;
}
.nav-item{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:6px 4px;cursor:pointer;
  transition:transform .15s;
}
.nav-item:active{transform:scale(0.9)}
.nav-icon-wrap{
  width:44px;height:28px;
  display:flex;align-items:center;justify-content:center;
  border-radius:14px;
  transition:background .2s;
}
.nav-item.active .nav-icon-wrap{background:rgba(124,58,237,0.2)}
.nav-svg{
  width:22px;height:22px;
  stroke:var(--text3);
  fill:none;
  stroke-width:1.6;
  stroke-linecap:round;
  stroke-linejoin:round;
  transition:stroke .2s;
}
.nav-item.active .nav-svg{stroke:var(--purple-light)}
.nav-label{
  font-size:9px;
  color:var(--text3);
  font-weight:400;
  transition:color .2s;
}
.nav-item.active .nav-label{color:var(--purple-light);font-weight:500}

/* ── SECTION TITLE ── */
.section-title{
  font-family:'Playfair Display',serif;
  font-size:22px;
  color:var(--text);
  font-weight:700;
  margin-bottom:4px;
}
.section-sub{
  font-size:13px;
  color:var(--text3);
  margin-bottom:20px;
}

/* ═══════════════════════════════
   TAB: DRESSING
═══════════════════════════════ */
.ai-generate-card{
  background:linear-gradient(135deg,var(--purple-dark),var(--purple));
  border-radius:var(--radius);
  padding:20px;
  margin-bottom:20px;
  position:relative;
  overflow:hidden;
  box-shadow:0 8px 32px var(--purple-glow);
}
.ai-generate-card::before{
  content:'';
  position:absolute;top:-40px;right:-40px;
  width:150px;height:150px;
  border-radius:50%;
  background:rgba(255,255,255,0.06);
}
.ai-generate-card h3{
  font-family:'Playfair Display',serif;
  font-size:18px;
  color:#fff;
  margin-bottom:4px;
  position:relative;
}
.ai-generate-card p{font-size:13px;color:rgba(255,255,255,0.7);margin-bottom:16px;position:relative}
.ai-btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 20px;
  background:#fff;
  color:var(--purple-dark);
  border:none;border-radius:var(--radius-sm);
  font-size:14px;font-weight:500;
  font-family:'DM Sans',sans-serif;
  cursor:pointer;
  transition:transform .15s, box-shadow .2s;
  position:relative;
}
.ai-btn:active{transform:scale(0.97)}
.ai-btn .spark{font-size:16px}

.dressing-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.dressing-header h3{font-size:15px;color:var(--text);font-weight:500}
.add-photo-btn{
  display:flex;align-items:center;gap:6px;
  padding:8px 14px;
  background:var(--card);
  border:1px dashed var(--border);
  border-radius:var(--radius-sm);
  color:var(--purple-light);
  font-size:13px;cursor:pointer;
  transition:background .2s;
}
.add-photo-btn:hover{background:var(--card2)}

.clothes-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:10px;
  margin-bottom:16px;
}
.cloth-item{
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:var(--radius-sm);
  aspect-ratio:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;overflow:hidden;position:relative;
}
.cloth-item img{width:100%;height:100%;object-fit:cover}
.cloth-emoji{font-size:32px;margin-bottom:4px}
.cloth-name{font-size:9px;color:var(--text3);text-align:center;padding:0 4px}
.cloth-item .cloth-badge{
  position:absolute;top:5px;right:5px;
  background:var(--purple);
  border-radius:50%;width:18px;height:18px;
  font-size:9px;color:#fff;
  display:flex;align-items:center;justify-content:center;
}

.add-cloth-item{
  border:1.5px dashed var(--border);
  border-radius:var(--radius-sm);
  aspect-ratio:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:4px;cursor:pointer;
  color:var(--text3);font-size:11px;
  transition:border-color .2s, color .2s;
}
.add-cloth-item:hover{border-color:var(--purple);color:var(--purple-light)}
.add-cloth-item .plus{
  font-size:22px;
  color:var(--purple-light);
}

/* AI Result */
.ai-result{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:18px;
  margin-top:16px;
  display:none;
  animation:fadeUp .4s both;
}
.ai-result.visible{display:block}
.ai-result-header{
  display:flex;align-items:center;gap:8px;margin-bottom:12px;
}
.ai-result-header .spark-badge{
  width:28px;height:28px;
  background:var(--purple);
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;
  box-shadow:0 2px 10px var(--purple-glow);
}
.ai-result-header h4{font-size:15px;color:var(--text);font-weight:500}
.ai-result-mood{
  font-size:11px;
  color:var(--purple-light);
  background:rgba(124,58,237,0.12);
  border-radius:20px;padding:4px 10px;
  display:inline-block;margin-bottom:12px;
}
.outfit-tags{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:12px}
.outfit-tag{
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:20px;padding:6px 13px;
  font-size:12px;color:var(--text);
}
.ai-advice{
  font-size:12px;color:var(--text3);line-height:1.6;
  border-top:1px solid var(--border2);padding-top:12px;
}
.ai-loading{
  display:none;align-items:center;gap:10px;padding:16px;
  color:var(--text3);font-size:13px;
}
.ai-loading.visible{display:flex}
.ai-spinner{
  width:18px;height:18px;border:2px solid var(--border);
  border-top-color:var(--purple);border-radius:50%;
  animation:spin .7s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}

/* Photo input */
#photo-input{display:none}

/* ═══════════════════════════════
   TAB: AVATAR
═══════════════════════════════ */
.avatar-stage{
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  padding:24px 16px;
  display:flex;flex-direction:column;align-items:center;
  margin-bottom:20px;
  position:relative;overflow:hidden;
}
.avatar-stage::before{
  content:'';
  position:absolute;bottom:0;left:0;right:0;height:100px;
  background:linear-gradient(0deg,rgba(124,58,237,0.08),transparent);
}
.avatar-svg-wrap{
  position:relative;z-index:1;
}
.avatar-caption{
  font-size:12px;color:var(--text3);margin-top:12px;
  position:relative;z-index:1;
}

.customizer{
  display:flex;flex-direction:column;gap:16px;
}
.custom-section{
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:var(--radius-sm);
  padding:14px;
}
.custom-section-title{
  font-size:11px;color:var(--text3);
  text-transform:uppercase;letter-spacing:.8px;
  margin-bottom:12px;
}
.color-palette{display:flex;gap:8px;flex-wrap:wrap}
.color-swatch{
  width:28px;height:28px;border-radius:50%;
  cursor:pointer;border:2px solid transparent;
  transition:transform .15s, border-color .15s;
}
.color-swatch:active{transform:scale(0.9)}
.color-swatch.selected{border-color:#fff;transform:scale(1.1)}

.avatar-option-row{
  display:flex;gap:8px;
}
.avatar-option{
  flex:1;
  background:var(--card2);
  border:1px solid var(--border2);
  border-radius:var(--radius-sm);
  padding:10px 8px;
  text-align:center;
  cursor:pointer;
  transition:border-color .2s, background .2s;
}
.avatar-option.selected{
  border-color:var(--purple);
  background:rgba(124,58,237,0.12);
}
.avatar-option-icon{font-size:22px;display:block;margin-bottom:4px}
.avatar-option-label{font-size:10px;color:var(--text3)}
.avatar-option.selected .avatar-option-label{color:var(--purple-light)}

/* ═══════════════════════════════
   TAB: ABONNEMENTS
═══════════════════════════════ */
.sub-cards{display:flex;flex-direction:column;gap:12px}
.sub-card{
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  padding:20px;
  position:relative;overflow:hidden;
}
.sub-card.featured{
  border-color:var(--purple);
  background:linear-gradient(135deg,var(--card),rgba(124,58,237,0.12));
}
.sub-card.featured::after{
  content:'POPULAIRE';
  position:absolute;top:16px;right:-22px;
  background:var(--gold);
  color:#1a0533;
  font-size:9px;font-weight:700;
  letter-spacing:1px;
  padding:4px 30px;
  transform:rotate(45deg);
}
.sub-plan-name{
  font-size:12px;font-weight:500;
  color:var(--text3);letter-spacing:1px;
  text-transform:uppercase;margin-bottom:6px;
}
.sub-card.featured .sub-plan-name{color:var(--purple-light)}
.sub-price-row{display:flex;align-items:baseline;gap:4px;margin-bottom:14px}
.sub-amount{
  font-family:'Playfair Display',serif;
  font-size:34px;color:var(--text);font-weight:700;
}
.sub-period{font-size:13px;color:var(--text3)}
.sub-features{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
.sub-feature{
  display:flex;align-items:center;gap:10px;
  font-size:13px;color:var(--text2);
}
.sub-check{
  width:18px;height:18px;border-radius:50%;
  background:rgba(124,58,237,0.15);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;color:var(--purple-light);font-size:10px;font-weight:700;
}
.sub-card.featured .sub-check{background:rgba(124,58,237,0.3)}
.sub-cta{
  width:100%;padding:13px;
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  color:var(--text2);font-size:14px;font-weight:500;
  font-family:'DM Sans',sans-serif;cursor:pointer;
  transition:background .2s;
}
.sub-card.featured .sub-cta{
  background:var(--purple);border-color:transparent;color:#fff;
  box-shadow:0 4px 16px var(--purple-glow);
}
.sub-card.free .sub-cta{opacity:.6;cursor:default}

/* ═══════════════════════════════
   TAB: PARAMÈTRES
═══════════════════════════════ */
.settings-group{margin-bottom:20px}
.settings-group-title{
  font-size:11px;color:var(--text3);
  text-transform:uppercase;letter-spacing:.8px;
  margin-bottom:8px;padding-left:4px;
}
.setting-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;
  background:var(--card);
  border:1px solid var(--border2);
  border-radius:var(--radius-sm);
  margin-bottom:4px;
  cursor:pointer;
  transition:background .2s;
}
.setting-row:hover{background:var(--card2)}
.setting-left{display:flex;align-items:center;gap:12px}
.setting-icon{
  width:32px;height:32px;border-radius:9px;
  background:rgba(124,58,237,0.15);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;
}
.setting-label{font-size:14px;color:var(--text);font-weight:400}
.setting-meta{font-size:12px;color:var(--text3);margin-top:1px}
.setting-right{display:flex;align-items:center;gap:8px}
.setting-value{font-size:13px;color:var(--text3)}
.setting-arrow{font-size:14px;color:var(--text3)}

.toggle-switch{
  width:42px;height:24px;
  background:var(--card2);
  border-radius:12px;
  position:relative;
  cursor:pointer;
  border:1px solid var(--border);
  transition:background .2s;
}
.toggle-switch.on{background:var(--purple);border-color:transparent}
.toggle-switch::after{
  content:'';
  position:absolute;
  width:18px;height:18px;
  border-radius:50%;background:#fff;
  top:2px;left:2px;
  transition:left .2s;
  box-shadow:0 1px 4px rgba(0,0,0,0.3);
}
.toggle-switch.on::after{left:20px}

.api-key-row{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:14px 16px;
  margin-bottom:4px;
}
.api-key-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.api-key-input-wrap{display:flex;gap:8px}
.api-key-input{
  flex:1;
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:10px 12px;
  color:var(--text);font-size:13px;
  font-family:'DM Sans',sans-serif;
  outline:none;
}
.api-key-input:focus{border-color:var(--purple)}
.api-save-btn{
  padding:10px 14px;
  background:var(--purple);color:#fff;
  border:none;border-radius:var(--radius-sm);
  font-size:13px;cursor:pointer;
  font-family:'DM Sans',sans-serif;
  white-space:nowrap;
}

.logout-btn{
  width:100%;padding:14px;
  background:transparent;
  border:1px solid rgba(239,68,68,0.3);
  border-radius:var(--radius-sm);
  color:#f87171;font-size:14px;
  font-family:'DM Sans',sans-serif;cursor:pointer;
  transition:background .2s;
  margin-top:8px;
}
.logout-btn:hover{background:rgba(239,68,68,0.08)}

/* ── TOAST ── */
.toast{
  position:fixed;
  bottom:calc(env(safe-area-inset-bottom,0px) + 90px);
  left:50%;transform:translateX(-50%) translateY(20px);
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:11px 20px;
  font-size:13px;color:var(--text);
  white-space:nowrap;
  opacity:0;
  transition:opacity .3s, transform .3s;
  z-index:999;
  pointer-events:none;
  box-shadow:0 8px 24px rgba(0,0,0,0.4);
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── USER AVATAR (header) ── */
.user-avatar{
  width:32px;height:32px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--purple),var(--purple-light));
  display:flex;align-items:center;justify-content:center;
  font-size:13px;color:#fff;font-weight:500;
  cursor:pointer;
  border:1.5px solid var(--border);
}
</style>
</head>
<body>
<div id="app">

<!-- ══════════════════════════
     SPLASH SCREEN
══════════════════════════ -->
<div class="screen active" id="splash">
  <div class="splash-bg">
    <div class="splash-orb orb1"></div>
    <div class="splash-orb orb2"></div>
    <div class="splash-orb orb3"></div>
  </div>
  <div class="splash-content">
    <div class="splash-logo">
      <svg class="hanger-svg" viewBox="0 0 52 52" fill="none">
        <path d="M26 12 C26 12 26 7 26 6 A4 4 0 0 1 34 6" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <path d="M26 12 L8 36 Q6 38 8 40 Q10 42 12 40 L26 28 L40 40 Q42 42 44 40 Q46 38 44 36 Z" fill="white"/>
      </svg>
    </div>
    <div class="splash-name">Dress<span>Code</span></div>
    <div class="splash-tagline">Votre style, sublimé par l'IA</div>
    <div class="splash-loader">
      <div class="splash-loader-bar" id="loaderBar"></div>
    </div>
  </div>
</div>

<!-- ══════════════════════════
     AUTH SCREEN
══════════════════════════ -->
<div class="screen" id="auth">
  <div class="auth-bg">
    <div class="auth-orb auth-orb1"></div>
    <div class="auth-orb auth-orb2"></div>
  </div>
  <div class="auth-inner">
    <div class="auth-top">
      <div class="auth-logo-small">
        <svg width="24" height="24" viewBox="0 0 52 52" fill="none">
          <path d="M26 12 C26 12 26 7 26 6 A4 4 0 0 1 34 6" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <path d="M26 12 L8 36 Q6 38 8 40 Q10 42 12 40 L26 28 L40 40 Q42 42 44 40 Q46 38 44 36 Z" fill="white"/>
        </svg>
      </div>
      <div class="auth-title" id="authTitle">Créer<br/>mon compte</div>
      <div class="auth-subtitle" id="authSubtitle">Rejoignez DressCode gratuitement</div>
    </div>
    <div class="auth-form">
      <div class="auth-error" id="authError"></div>
      <div class="input-group" id="nameGroup">
        <label class="input-label">Prénom</label>
        <input class="dc-input" id="nameInput" type="text" placeholder="Votre prénom" autocomplete="given-name"/>
      </div>
      <div class="input-group">
        <label class="input-label">Email</label>
        <input class="dc-input" id="emailInput" type="email" placeholder="votre@email.com" autocomplete="email"/>
      </div>
      <div class="input-group">
        <label class="input-label">Mot de passe</label>
        <input class="dc-input" id="passwordInput" type="password" placeholder="••••••••" autocomplete="current-password"/>
      </div>
      <button class="dc-btn" id="authSubmitBtn" onclick="handleAuth()">Créer mon compte</button>
      <div class="auth-divider"><span>ou</span></div>
      <button class="dc-btn-outline" onclick="toggleAuthMode()">
        <span id="authToggleLabel">J'ai déjà un compte – Me connecter</span>
      </button>
      <div class="auth-switch-text">
        En continuant, vous acceptez les <button onclick="showToast('Conditions disponibles bientôt')">conditions d'utilisation</button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════
     MAIN APP
══════════════════════════ -->
<div class="screen" id="main">
  <div class="app-header">
    <div class="app-header-left">
      <div class="header-logo">
        <svg width="20" height="20" viewBox="0 0 52 52" fill="none">
          <path d="M26 12 C26 12 26 7 26 6 A4 4 0 0 1 34 6" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <path d="M26 12 L8 36 Q6 38 8 40 Q10 42 12 40 L26 28 L40 40 Q42 42 44 40 Q46 38 44 36 Z" fill="white"/>
        </svg>
      </div>
      <div>
        <div style="font-family:'Playfair Display',serif;font-size:17px;color:var(--text);font-weight:700;line-height:1">DressCode</div>
        <div id="currentTabTitle" style="font-size:11px;color:var(--text3)">Mon dressing</div>
      </div>
    </div>
    <div class="header-actions">
      <div class="user-avatar" id="userAvatarBadge">?</div>
    </div>
  </div>

  <div class="tab-area">
    <!-- DRESSING TAB -->
    <div class="tab-panel active" id="panelDressing">
      <div class="ai-generate-card">
        <h3>✦ Générer une tenue</h3>
        <p>L'IA analyse votre dressing et crée la tenue parfaite</p>
        <button class="ai-btn" onclick="generateOutfit()">
          <span class="spark">✦</span> Créer ma tenue du jour
        </button>
      </div>
      <div class="ai-loading" id="aiLoading">
        <div class="ai-spinner"></div>
        L'IA compose votre tenue…
      </div>
      <div class="ai-result" id="aiResult">
        <div class="ai-result-header">
          <div class="spark-badge">✦</div>
          <h4>Tenue suggérée</h4>
        </div>
        <div class="ai-result-mood" id="aiMood">Smart casual</div>
        <div class="outfit-tags" id="outfitTags"></div>
        <div class="ai-advice" id="aiAdvice"></div>
      </div>

      <div class="dressing-header">
        <h3 style="font-size:15px;color:var(--text)">Ma garde-robe</h3>
        <label class="add-photo-btn" for="photo-input" onclick="event.stopPropagation()">
          <span>+</span> Ajouter
        </label>
        <input type="file" id="photo-input" accept="image/*" capture="environment" onchange="addCloth(event)" style="display:none;position:absolute;left:-9999px;"/>
      </div>
      <div class="clothes-grid" id="clothesGrid">
        <div class="cloth-item"><div class="cloth-emoji">👔</div><div class="cloth-name">Chemise blanche</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👖</div><div class="cloth-name">Jean slim bleu</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👟</div><div class="cloth-name">Sneakers blanches</div></div>
        <div class="cloth-item"><div class="cloth-emoji">🧥</div><div class="cloth-name">Blazer marine</div></div>
        <div class="cloth-item"><div class="cloth-emoji">👗</div><div class="cloth-name">Robe fleurie</div></div>
        <label class="add-cloth-item" for="photo-input" onclick="event.stopPropagation()">
          <div class="plus">+</div>
          Photographier
        </label>
      </div>
    </div>

    <!-- AVATAR TAB -->
    <div class="tab-panel" id="panelAvatar">
      <div class="section-title">Mon Avatar</div>
      <div class="section-sub">Personnalisez votre double virtuel</div>
      <div class="avatar-stage">
        <div class="avatar-svg-wrap">
          <svg id="avatarSvg" width="140" height="220" viewBox="0 0 140 220">
            <!-- Corps -->
            <ellipse cx="70" cy="180" rx="35" ry="8" fill="rgba(124,58,237,0.1)"/>
            <!-- Jambes -->
            <rect id="avPantsL" x="45" y="148" width="22" height="60" rx="8" fill="#185FA5"/>
            <rect id="avPantsR" x="73" y="148" width="22" height="60" rx="8" fill="#185FA5"/>
            <!-- Chaussures -->
            <rect x="43" y="200" width="24" height="12" rx="5" fill="#2C2C2A"/>
            <rect x="73" y="200" width="24" height="12" rx="5" fill="#2C2C2A"/>
            <!-- Bras -->
            <rect id="avArmL" x="22" y="88" width="16" height="52" rx="8" fill="#7c3aed"/>
            <rect id="avArmR" x="102" y="88" width="16" height="52" rx="8" fill="#7c3aed"/>
            <!-- Corps/Haut -->
            <rect id="avShirt" x="38" y="82" width="64" height="72" rx="12" fill="#7c3aed"/>
            <!-- Cou -->
            <rect id="avNeck" x="62" y="75" width="16" height="16" rx="4" fill="#FAEEDA"/>
            <!-- Tête -->
            <ellipse id="avHead" cx="70" cy="55" rx="30" ry="34" fill="#FAEEDA"/>
            <!-- Cheveux -->
            <path id="avHair" d="M40 42 Q40 18 70 16 Q100 18 100 42 Q100 30 70 28 Q40 30 40 42Z" fill="#5a3310"/>
            <!-- Yeux -->
            <circle cx="60" cy="52" r="4" fill="white"/>
            <circle cx="80" cy="52" r="4" fill="white"/>
            <circle cx="61" cy="53" r="2" fill="#2C2C2A"/>
            <circle cx="81" cy="53" r="2" fill="#2C2C2A"/>
            <!-- Sourcils -->
            <path d="M55 46 Q60 44 65 46" stroke="#5a3310" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M75 46 Q80 44 85 46" stroke="#5a3310" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <!-- Nez -->
            <ellipse cx="70" cy="60" rx="3" ry="2" fill="rgba(0,0,0,0.08)"/>
            <!-- Bouche -->
            <path d="M63 67 Q70 73 77 67" stroke="#c47" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="avatar-caption">Votre avatar DressCode</div>
      </div>

      <div class="customizer">
        <div class="custom-section">
          <div class="custom-section-title">Couleur de peau</div>
          <div class="color-palette">
            <div class="color-swatch selected" style="background:#FAEEDA" data-type="skin" data-val="#FAEEDA" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#E8B89A" data-type="skin" data-val="#E8B89A" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#C68642" data-type="skin" data-val="#C68642" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#8D5524" data-type="skin" data-val="#8D5524" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#4A2912" data-type="skin" data-val="#4A2912" onclick="setAvatarColor(this)"></div>
          </div>
        </div>
        <div class="custom-section">
          <div class="custom-section-title">Couleur des cheveux</div>
          <div class="color-palette">
            <div class="color-swatch selected" style="background:#5a3310" data-type="hair" data-val="#5a3310" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#1a1a1a" data-type="hair" data-val="#1a1a1a" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#C68642" data-type="hair" data-val="#C68642" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#e8d5b7" data-type="hair" data-val="#e8d5b7" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#c0392b" data-type="hair" data-val="#c0392b" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#8e44ad" data-type="hair" data-val="#8e44ad" onclick="setAvatarColor(this)"></div>
          </div>
        </div>
        <div class="custom-section">
          <div class="custom-section-title">Couleur du haut</div>
          <div class="color-palette">
            <div class="color-swatch selected" style="background:#7c3aed" data-type="shirt" data-val="#7c3aed" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#E24B4A" data-type="shirt" data-val="#E24B4A" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#1D9E75" data-type="shirt" data-val="#1D9E75" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#185FA5" data-type="shirt" data-val="#185FA5" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#2C2C2A" data-type="shirt" data-val="#2C2C2A" onclick="setAvatarColor(this)"></div>
            <div class="color-swatch" style="background:#f0f0f0;border:1px solid rgba(255,255,255,0.2)" data-type="shirt" data-val="#f0f0f0" onclick="setAvatarColor(this)"></div>
          </div>
        </div>
        <div class="custom-section">
          <div class="custom-section-title">Style de cheveux</div>
          <div class="avatar-option-row">
            <div class="avatar-option selected" data-hair="short" onclick="selectHairStyle(this,'short')">
              <span class="avatar-option-icon">💈</span>
              <span class="avatar-option-label">Court</span>
            </div>
            <div class="avatar-option" data-hair="medium" onclick="selectHairStyle(this,'medium')">
              <span class="avatar-option-icon">💇</span>
              <span class="avatar-option-label">Mi-long</span>
            </div>
            <div class="avatar-option" data-hair="long" onclick="selectHairStyle(this,'long')">
              <span class="avatar-option-icon">🧖</span>
              <span class="avatar-option-label">Long</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ABONNEMENTS TAB -->
    <div class="tab-panel" id="panelSub">
      <div class="section-title">Abonnements</div>
      <div class="section-sub">Choisissez votre formule DressCode</div>
      <div class="sub-cards">
        <div class="sub-card free">
          <div class="sub-plan-name">Gratuit</div>
          <div class="sub-price-row">
            <div class="sub-amount">0€</div>
            <div class="sub-period">/ mois</div>
          </div>
          <ul class="sub-features">
            <li class="sub-feature"><div class="sub-check">✓</div>5 tenues générées / mois</li>
            <li class="sub-feature"><div class="sub-check">✓</div>20 vêtements dans le dressing</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Avatar de base</li>
          </ul>
          <button class="sub-cta">Plan actuel</button>
        </div>
        <div class="sub-card featured">
          <div class="sub-plan-name">Style ✦</div>
          <div class="sub-price-row">
            <div class="sub-amount">4,99€</div>
            <div class="sub-period">/ mois</div>
          </div>
          <ul class="sub-features">
            <li class="sub-feature"><div class="sub-check">✓</div>50 tenues générées / mois</li>
            <li class="sub-feature"><div class="sub-check">✓</div>100 vêtements dans le dressing</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Avatar personnalisé avancé</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Historique complet des tenues</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Suggestions météo</li>
          </ul>
          <button class="sub-cta" onclick="showToast('Paiement disponible bientôt !')">Choisir Style</button>
        </div>
        <div class="sub-card">
          <div class="sub-plan-name">Premium</div>
          <div class="sub-price-row">
            <div class="sub-amount">9,99€</div>
            <div class="sub-period">/ mois</div>
          </div>
          <ul class="sub-features">
            <li class="sub-feature"><div class="sub-check">✓</div>Tenues illimitées</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Dressing illimité</li>
            <li class="sub-feature"><div class="sub-check">✓</div>IA météo & agenda connecté</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Accès en avant-première</li>
            <li class="sub-feature"><div class="sub-check">✓</div>Support prioritaire</li>
          </ul>
          <button class="sub-cta" onclick="showToast('Paiement disponible bientôt !')">Choisir Premium</button>
        </div>
      </div>
    </div>

    <!-- PARAMÈTRES TAB -->
    <div class="tab-panel" id="panelSettings">
      <div class="section-title">Paramètres</div>

      <div class="settings-group">
        <div class="settings-group-title">Clé API Anthropic (IA)</div>
        <div class="api-key-row">
          <div class="api-key-label">Entrez votre clé pour activer la génération IA</div>
          <div class="api-key-input-wrap">
            <input class="api-key-input" id="apiKeyInput" type="password" placeholder="sk-ant-..." autocomplete="off"/>
            <button class="api-save-btn" onclick="saveApiKey()">Enregistrer</button>
          </div>
          <div style="font-size:11px;color:var(--text3);margin-top:8px">
            Obtenez votre clé gratuite sur <a href="https://console.anthropic.com" style="color:var(--purple-light)">console.anthropic.com</a>
          </div>
        </div>
      </div>

      <div class="settings-group">
        <div class="settings-group-title">Apparence</div>
        <div class="setting-row" onclick="toggleTheme()">
          <div class="setting-left">
            <div class="setting-icon">◑</div>
            <div>
              <div class="setting-label">Mode sombre</div>
              <div class="setting-meta">Thème actuel</div>
            </div>
          </div>
          <div class="toggle-switch on" id="darkToggle"></div>
        </div>
        <div class="setting-row" onclick="showToast('Multi-langue bientôt disponible')">
          <div class="setting-left">
            <div class="setting-icon">🌐</div>
            <div class="setting-label">Langue</div>
          </div>
          <div class="setting-right">
            <div class="setting-value">Français</div>
            <div class="setting-arrow">›</div>
          </div>
        </div>
      </div>

      <div class="settings-group">
        <div class="settings-group-title">Contenu</div>
        <div class="setting-row" onclick="switchTab('dressing')">
          <div class="setting-left">
            <div class="setting-icon">✦</div>
            <div>
              <div class="setting-label">Tenues générées</div>
              <div class="setting-meta" id="outfitCount">0 tenue(s)</div>
            </div>
          </div>
          <div class="setting-arrow">›</div>
        </div>
        <div class="setting-row" onclick="toggleNotif()">
          <div class="setting-left">
            <div class="setting-icon">🔔</div>
            <div class="setting-label">Notifications</div>
          </div>
          <div class="toggle-switch" id="notifToggle"></div>
        </div>
      </div>

      <div class="settings-group">
        <div class="settings-group-title">Compte</div>
        <div class="setting-row">
          <div class="setting-left">
            <div class="setting-icon">👤</div>
            <div>
              <div class="setting-label">Mon profil</div>
              <div class="setting-meta" id="userEmailDisplay">—</div>
            </div>
          </div>
          <div class="setting-arrow">›</div>
        </div>
        <div class="setting-row" onclick="switchTab('sub')">
          <div class="setting-left">
            <div class="setting-icon">💳</div>
            <div class="setting-label">Abonnement</div>
          </div>
          <div class="setting-right">
            <div class="setting-value">Gratuit</div>
            <div class="setting-arrow">›</div>
          </div>
        </div>
        <button class="logout-btn" onclick="handleLogout()">Se déconnecter</button>
      </div>
    </div>
  </div><!-- end tab-area -->

  <!-- BOTTOM NAV -->
  <div class="bottom-nav">
    <div class="nav-item active" id="navDressing" onclick="switchTab('dressing')">
      <div class="nav-icon-wrap">
        <svg class="nav-svg" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <div class="nav-label">Dressing</div>
    </div>
    <div class="nav-item" id="navAvatar" onclick="switchTab('avatar')">
      <div class="nav-icon-wrap">
        <svg class="nav-svg" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div class="nav-label">Avatar</div>
    </div>
    <div class="nav-item" id="navSub" onclick="switchTab('sub')">
      <div class="nav-icon-wrap">
        <svg class="nav-svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="nav-label">Plans</div>
    </div>
    <div class="nav-item" id="navSettings" onclick="switchTab('settings')">
      <div class="nav-icon-wrap">
        <svg class="nav-svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </div>
      <div class="nav-label">Réglages</div>
    </div>
  </div>
</div><!-- end main -->

</div><!-- end app -->

<div class="toast" id="toast"></div>

<script>
/* ── FIREBASE CONFIG ──
   ⚠️  REMPLACE ces valeurs par celles de ton projet Firebase
   (Paramètres du projet → Apps → Ton app web → Config SDK)
*/
const firebaseConfig = {
  apiKey: "AIzaSyCMGAZ4OeKhDskKIVM-tnpyH14E1ebD1_g",
  authDomain: "dresscode-69adb.firebaseapp.com",
  projectId: "dresscode-69adb",
  storageBucket: "dresscode-69adb.firebasestorage.app",
  messagingSenderId: "824734866282",
  appId: "1:824734866282:web:88650ff621bef6e3242313"
};

let db, storage, auth, currentUser;
let outfitCount = 0;
let isLoginMode = false;
let ANTHROPIC_API_KEY = localStorage.getItem('dc_api_key') || '';

/* ── INIT FIREBASE ── */
try {
  firebase.initializeApp(firebaseConfig);
  auth    = firebase.auth();
  db      = firebase.firestore();
  storage = firebase.storage();
  console.log('✅ Firebase initialisé');
  auth.onAuthStateChanged(user => {
    if (user) {
      currentUser = user;
      // Si le splash est encore visible, attendre qu'il finisse
      const splash = document.getElementById('splash');
      if (splash && splash.classList.contains('active')) {
        setTimeout(() => onUserLoggedIn(user), 1200);
      } else {
        onUserLoggedIn(user);
      }
    }
  });
} catch(e) {
  console.warn('⚠️ Firebase non configuré — mode démo:', e.message);
}

/* ── SPLASH SCREEN ── */
let progress = 0;
const bar = document.getElementById('loaderBar');
const loaderInterval = setInterval(() => {
  progress = Math.min(progress + (Math.random() * 3 + 1), 100);
  bar.style.width = progress + '%';
  if (progress >= 100) {
    clearInterval(loaderInterval);
    setTimeout(() => {
      if (auth && auth.currentUser) return;
      showScreen('auth');
    }, 400);
  }
}, 60);

/* ── SCREENS ── */
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* ── AUTH ── */
function toggleAuthMode() {
  isLoginMode = !isLoginMode;
  const nameGroup = document.getElementById('nameGroup');
  const authTitle = document.getElementById('authTitle');
  const authSubtitle = document.getElementById('authSubtitle');
  const submitBtn = document.getElementById('authSubmitBtn');
  const toggleLabel = document.getElementById('authToggleLabel');

  if (isLoginMode) {
    nameGroup.style.display = 'none';
    authTitle.innerHTML = 'Bon<br/>retour !';
    authSubtitle.textContent = 'Connectez-vous à DressCode';
    submitBtn.textContent = 'Me connecter';
    toggleLabel.textContent = 'Pas encore de compte – Créer le mien';
  } else {
    nameGroup.style.display = '';
    authTitle.innerHTML = 'Créer<br/>mon compte';
    authSubtitle.textContent = 'Rejoignez DressCode gratuitement';
    submitBtn.textContent = 'Créer mon compte';
    toggleLabel.textContent = "J'ai déjà un compte – Me connecter";
  }
  clearAuthError();
}

function showAuthError(msg) {
  const el = document.getElementById('authError');
  el.textContent = msg;
  el.classList.add('visible');
}
function clearAuthError() {
  document.getElementById('authError').classList.remove('visible');
}

async function handleAuth() {
  const email    = document.getElementById('emailInput').value.trim();
  const password = document.getElementById('passwordInput').value;
  const name     = document.getElementById('nameInput').value.trim();
  const btn      = document.getElementById('authSubmitBtn');

  clearAuthError();
  if (!email || !password) { showAuthError('Merci de remplir tous les champs.'); return; }
  if (!isLoginMode && !name) { showAuthError('Entrez votre prénom.'); return; }
  if (password.length < 6) { showAuthError('Le mot de passe doit faire au moins 6 caractères.'); return; }

  btn.classList.add('loading');
  btn.disabled = true;

  try {
    if (!auth) {
      await new Promise(r => setTimeout(r, 1000));
      onUserLoggedIn({ email, displayName: name || email.split('@')[0] });
      return;
    }
    if (isLoginMode) {
      const result = await auth.signInWithEmailAndPassword(email, password);
      onUserLoggedIn(result.user);
    } else {
      const cred = await auth.createUserWithEmailAndPassword(email, password);
      await cred.user.updateProfile({ displayName: name });
      try {
        if (db) {
          await db.collection('users').doc(cred.user.uid).set({
            name, email, createdAt: new Date().toISOString()
          });
        }
      } catch(dbErr) { console.warn('Firestore non dispo, on continue:', dbErr); }
      onUserLoggedIn(cred.user);
    }
  } catch(e) {
    console.error('Auth error:', e.code, e.message);
    const msgs = {
      'auth/email-already-in-use': 'Cet email est déjà utilisé.',
      'auth/user-not-found': 'Aucun compte avec cet email.',
      'auth/wrong-password': 'Mot de passe incorrect.',
      'auth/invalid-credential': 'Email ou mot de passe incorrect.',
      'auth/invalid-email': 'Email invalide.',
      'auth/too-many-requests': 'Trop de tentatives. Réessayez plus tard.',
      'auth/network-request-failed': 'Erreur réseau. Vérifiez votre connexion.',
      'auth/operation-not-allowed': 'Connexion email non activée dans Firebase.',
    };
    showAuthError(msgs[e.code] || 'Erreur (' + e.code + '): ' + e.message);
    btn.classList.remove('loading');
    btn.disabled = false;
  }
}

function onUserLoggedIn(user) {
  currentUser = user;
  const name = user.displayName || user.email || 'Vous';
  const initial = name.charAt(0).toUpperCase();
  document.getElementById('userAvatarBadge').textContent = initial;
  document.getElementById('userEmailDisplay').textContent = user.email || name;
  if (ANTHROPIC_API_KEY) document.getElementById('apiKeyInput').value = '••••••••';
  showScreen('main');
}

function handleLogout() {
  if (auth) auth.signOut();
  showScreen('auth');
  showToast('À bientôt !');
}

/* ── TABS ── */
const tabTitles = {
  dressing:'Mon dressing',avatar:'Mon avatar',sub:'Abonnements',settings:'Paramètres'
};
function switchTab(tab) {
  ['dressing','avatar','sub','settings'].forEach(t => {
    document.getElementById('panel' + t.charAt(0).toUpperCase() + t.slice(1)).classList.toggle('active', t === tab);
    document.getElementById('nav' + t.charAt(0).toUpperCase() + t.slice(1)).classList.toggle('active', t === tab);
  });
  document.getElementById('currentTabTitle').textContent = tabTitles[tab];
}

/* ── AVATAR ── */
function setAvatarColor(el) {
  const type = el.dataset.type;
  const val  = el.dataset.val;
  el.closest('.color-palette').querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  const svg = document.getElementById('avatarSvg');
  if (type === 'skin') {
    svg.querySelectorAll('#avHead,#avNeck').forEach(e => e.setAttribute('fill', val));
    const skinEllipses = svg.querySelectorAll('ellipse');
    skinEllipses.forEach(e => { if(parseFloat(e.getAttribute('cx'))===70 && parseFloat(e.getAttribute('cy'))===55) e.setAttribute('fill',val); });
    document.getElementById('avHead').setAttribute('fill',val);
    document.getElementById('avNeck').setAttribute('fill',val);
  } else if (type === 'hair') {
    document.getElementById('avHair').setAttribute('fill', val);
    svg.querySelectorAll('path[stroke="#5a3310"]').forEach(p => p.setAttribute('stroke',val));
  } else if (type === 'shirt') {
    document.getElementById('avShirt').setAttribute('fill', val);
    document.getElementById('avArmL').setAttribute('fill', val);
    document.getElementById('avArmR').setAttribute('fill', val);
  }
}

function selectHairStyle(el, style) {
  el.closest('.avatar-option-row').querySelectorAll('.avatar-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  const hair = document.getElementById('avHair');
  if (style === 'short') hair.setAttribute('d','M40 42 Q40 18 70 16 Q100 18 100 42 Q100 30 70 28 Q40 30 40 42Z');
  if (style === 'medium') hair.setAttribute('d','M40 42 Q38 18 70 14 Q102 18 100 42 Q100 28 70 26 Q40 28 40 42 M40 42 Q35 60 38 70 M100 42 Q105 60 102 70Z');
  if (style === 'long') hair.setAttribute('d','M40 42 Q36 18 70 12 Q104 18 100 42 Q100 26 70 24 Q40 26 40 42 M40 42 Q32 65 34 90 M100 42 Q108 65 106 90Z');
  showToast('Style appliqué !');
}

/* ── OUTFIT GENERATION ── */
async function generateOutfit() {
  const loading = document.getElementById('aiLoading');
  const result  = document.getElementById('aiResult');
  result.classList.remove('visible');
  loading.classList.add('visible');

  const clothes = ['Chemise blanche','Jean slim bleu','Sneakers blanches','Blazer marine','Robe fleurie'];

  if (!ANTHROPIC_API_KEY) {
    await new Promise(r => setTimeout(r, 1500));
    loading.classList.remove('visible');
    showDemoOutfit(clothes);
    return;
  }

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key': ANTHROPIC_API_KEY,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:400,
        messages:[{
          role:'user',
          content:`Tu es un styliste expert. Voici les vêtements disponibles dans mon dressing : ${clothes.join(', ')}. 
          Génère une tenue complète et donne des conseils. Réponds UNIQUEMENT en JSON valide sans aucune explication :
          {"mood":"style en 2-3 mots","items":["vêtement1","vêtement2","vêtement3"],"conseil":"conseil en 1 phrase courte"}`
        }]
      })
    });
    const data = await resp.json();
    const text = data.content[0].text;
    const json = JSON.parse(text.replace(/```json|```/g,'').trim());
    loading.classList.remove('visible');
    showOutfit(json.mood, json.items, json.conseil);
  } catch(e) {
    console.error(e);
    loading.classList.remove('visible');
    showDemoOutfit(clothes);
  }
}

function showDemoOutfit(clothes) {
  showOutfit(
    'Smart casual',
    ['Chemise blanche','Jean slim bleu','Sneakers blanches'],
    "Retroussez légèrement les manches pour un effet plus décontracté et accessible."
  );
}

function showOutfit(mood, items, conseil) {
  document.getElementById('aiMood').textContent = mood;
  document.getElementById('outfitTags').innerHTML = items.map(i => `<span class="outfit-tag">${i}</span>`).join('');
  document.getElementById('aiAdvice').textContent = '💡 ' + conseil;
  document.getElementById('aiResult').classList.add('visible');
  outfitCount++;
  document.getElementById('outfitCount').textContent = outfitCount + ' tenue(s)';
}

/* ── ADD CLOTH (photo) ── */
function addCloth(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    const grid = document.getElementById('clothesGrid');
    const lastItem = grid.querySelector('.add-cloth-item');
    const div = document.createElement('div');
    div.className = 'cloth-item';
    div.innerHTML = `<img src="${ev.target.result}" style="width:100%;height:100%;object-fit:cover"/><span class="cloth-badge">✓</span>`;
    grid.insertBefore(div, lastItem);
    showToast('Vêtement ajouté !');
  };
  reader.readAsDataURL(file);
}

/* ── SETTINGS ── */
function saveApiKey() {
  const val = document.getElementById('apiKeyInput').value.trim();
  if (!val || val === '••••••••') { showToast('Entrez votre clé API'); return; }
  ANTHROPIC_API_KEY = val;
  localStorage.setItem('dc_api_key', val);
  document.getElementById('apiKeyInput').value = '••••••••';
  showToast('✅ Clé API enregistrée !');
}

function toggleTheme() {
  document.getElementById('darkToggle').classList.toggle('on');
  showToast('Thème bientôt disponible');
}

function toggleNotif() {
  document.getElementById('notifToggle').classList.toggle('on');
}

/* ── TOAST ── */
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}
</script>
</body>
</html>
